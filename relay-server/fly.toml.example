# Example Fly.io config — copy to fly.toml and set YOUR app name.
# Do not commit a fly.toml that points at a personal production app.

app = 'YOUR-APP-NAME'
primary_region = 'sjc'

[build]

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = 'off'
  auto_start_machines = true
  min_machines_running = 1
  processes = ['app']

[[vm]]
  memory = '1gb'
  cpu_kind = 'shared'
  cpus = 1
  memory_mb = 1024
